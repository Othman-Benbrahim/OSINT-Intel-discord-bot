# Token d'accès HuggingFace
# → https://huggingface.co/settings/tokens → New token (rôle : Read)
HF_TOKEN=

# Modèle HuggingFace à utiliser
# Recommandés :
#   mistralai/Mixtral-8x7B-Instruct-v0.1   (meilleure qualité)
#   mistralai/Mistral-7B-Instruct-v0.3     (plus rapide)
#   meta-llama/Meta-Llama-3.1-8B-Instruct  (nécessite acceptation licence Meta)
HF_MODEL=Qwen/Qwen3.6-35B-A3B

# Token de votre bot Discord
# → https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=
